        var oc = document.getElementById('orrery-canvas');
        if (!oc) return;
        var off = (window.Orrery3D && typeof Orrery3D.captureFrame === 'function')
          ? Orrery3D.captureFrame({ scale: 2 })
          : null;
        if (!off) {
          off = document.createElement('canvas');
          off.width = oc.width; off.height = oc.height;
          var ctx0 = off.getContext('2d');
          ctx0.fillStyle = '#050406';
          ctx0.fillRect(0, 0, off.width, off.height);
          try { ctx0.drawImage(oc, 0, 0); } catch(e) { return; }
        }
        var W = off.width, H = off.height;
        var ctx = off.getContext('2d');
        var fs = Math.max(11, Math.round(H * 0.022));
        ctx.font = '600 ' + fs + 'px Cinzel, serif';
        ctx.fillStyle = 'rgba(201,162,39,0.55)';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'bottom';
        ctx.fillText('AstroPrecise', W - 14, H - 10);
        var dateEl = document.getElementById('orrery-date-display');
        var dateStr = dateEl ? dateEl.textContent.trim() : '';
        if (dateStr) {
          ctx.font = '400 ' + Math.max(9, Math.round(H * 0.016)) + 'px Cinzel, serif';
          ctx.fillStyle = 'rgba(201,162,39,0.4)';
          ctx.fillText(dateStr, W - 14, H - 10 - fs - 4);
        }
        off.toBlob(function(blob) {
          var slug = (dateStr || 'now').replace(/[^a-z0-9]/gi, '-').toLowerCase();
          var fname = 'sky-' + slug + '.png';
          var file = new File([blob], fname, { type: 'image/png' });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            navigator.share({ files: [file], title: 'My Sky — AstroPrecise', text: 'The living sky · ' + dateStr }).catch(function(){});
          } else {
            var a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = fname;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            setTimeout(function(){ URL.revokeObjectURL(a.href); }, 2000);
          }
        }, 'image/png');
      });
    })();

