        if (!orrSlot || preDone) return;
        if (!preloaderWebGLSafe()) {
          useCssPreloaderFallback();
          return;
        }

        var engineLoad = (typeof window.__loadOrreryEngine === 'function')
          ? window.__loadOrreryEngine().catch(function () {})
          : Promise.resolve();

        orrViewport = await waitForOrreryViewport(12000);
        if (!orrViewport || preDone) {
          if (!preDone) useCssPreloaderFallback();
          return;
        }
        heroRing = orrViewport.parentElement;
        if (heroRing) heroRing.classList.add('orrery-canvas-away');
        orrSlot.appendChild(orrViewport);
        orreryRelocated = true;
        pre.classList.add('has-live-orr');
        await afterLayout();
        if (preDone) return;

        await engineLoad;
        var engineReady = await waitForGlobal(function () {
          return window.Orrery3D && window.AstroEphemeris && typeof Orrery3D.init === 'function';
        }, 20000);
        if (!engineReady || preDone) {
          if (!preDone) useCssPreloaderFallback();
          return;
        }
        try {
          if (!window.__orreryReady) {
            window.Orrery3D.init(document.getElementById('orrery-canvas'));
            window.__orreryReady = true;
          }
          refitPreloaderOrrery();
          if (typeof window.Orrery3D.setSpeed === 'function') window.Orrery3D.setSpeed(0);
          if (typeof window.Orrery3D.whenEarthReady === 'function') {
            await window.Orrery3D.whenEarthReady();
          }
          if (preDone) return;
          pre.classList.add('orrery-expanded');
          wireEnterButton();
          refitPreloaderOrrery();
          requestAnimationFrame(function () {
            refitPreloaderOrrery();
            setTimeout(refitPreloaderOrrery, 200);
          });
          if (typeof window.Orrery3D.startPreloaderIntro === 'function') {
            window.Orrery3D.startPreloaderIntro(revealEnter);
          } else if (typeof window.Orrery3D.restartIntro === 'function') {
            window.Orrery3D.onIntroDone = revealEnter;
            window.Orrery3D.restartIntro();
          }
          pre.classList.add('has-real');
          if (window.CosmosEngine && typeof window.CosmosEngine.setPreloaderPause === 'function') {
            window.CosmosEngine.setPreloaderPause(true);
          }
          orrSlot.setAttribute('aria-hidden', 'false');
          refitPreloaderOrrery();
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              refitPreloaderOrrery();
              setTimeout(refitPreloaderOrrery, 120);
              setTimeout(refitPreloaderOrrery, 400);
            });
          });
        } catch (e) {
          if (!preDone) useCssPreloaderFallback();
        }
      })();
    }
    setTimeout(function () {
      if (!preDone && !pre.classList.contains('has-real') && !pre.classList.contains('fallback-css')) {
        useCssPreloaderFallback();
      }
    }, 14000);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', featureOrreryOnLoadingScreen);
    } else {
      featureOrreryOnLoadingScreen();
    }

    var gateEl = document.getElementById('preloader-email-gate');
    var gateClose = document.getElementById('preloader-gate-close');
    var gateSkip = document.getElementById('preloader-gate-skip');
    var gateJoin = document.getElementById('preloader-gate-join');
    var gateOpen = false;
    if (gateEl) {
      gateEl.classList.remove('is-open');
      gateEl.setAttribute('aria-hidden', 'true');
    }

    function captureIntroEmail(email) {
      if (window.AstroApp && typeof window.AstroApp.captureEmail === 'function') {
        window.AstroApp.captureEmail(email, { source: 'intro_entry', tag: 'tag_intro_entry' });
        return;
      }
      try {
        var body = new FormData();
        body.append('email', email);
        body.append('tags', 'tag_intro_entry');
        fetch('https://list.astroprecise.app/subscribe', { method: 'POST', mode: 'no-cors', body: body });
      } catch (e) {}
    }

    function tryJoinIntroEmail() {
      var inp = document.getElementById('preloader-gate-email');
      if (!inp) return true;
      var email = (inp.value || '').trim();
      if (!email) {
        if (window.AstroApp && typeof AstroApp.showToast === 'function') {
          AstroApp.showToast('Add your email', 'Or tap Continue without email.', 'warning');
        }
        return false;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (window.AstroApp && typeof AstroApp.showToast === 'function') {
          AstroApp.showToast('Check your email', 'That address looks off.', 'warning');
        }
        return false;
      }
      captureIntroEmail(email);
      return true;
    }

    function dismissEmailGate(andCapture) {
      if (preDone) return;
      if (andCapture && !tryJoinIntroEmail()) return;
      if (gateEl) {
        gateEl.classList.remove('is-open');
        gateEl.setAttribute('aria-hidden', 'true');
      }
      pre.classList.remove('gate-open');
      gateOpen = false;
      hidePre();
    }

    function enterSite() {
      if (preDone) return;
      if (gateOpen) {
        if (gateEl) {
          gateEl.classList.remove('is-open');
          gateEl.setAttribute('aria-hidden', 'true');
        }
        pre.classList.remove('gate-open');
        gateOpen = false;
      }
      if (enterBtn) enterBtn.classList.add('preloader-enter-btn--launch');
      hidePre();
    }

    function rearmEnterButton() {
      wireEnterButton();
    }

    function wireEnterButton() {
      if (!enterBtn || preDone || enterBtn.dataset.wired === '1') return;
      enterBtn.dataset.wired = '1';
      enterBtn.addEventListener('click', function (ev) {
        ev.preventDefault();
        enterSite();
      });
    }

    function showEmailGate() {
      if (preDone || gateOpen || !gateEl) return;
      gateOpen = true;
      pre.classList.add('gate-open');
      gateEl.setAttribute('aria-hidden', 'false');
      gateEl.classList.add('is-open');
    }

    function onGateAction(ev, andCapture) {
      if (ev) { ev.preventDefault(); ev.stopPropagation(); }
      dismissEmailGate(andCapture);
    }

    function wireEmailGate() {
      if (!gateEl || gateEl.dataset.wired) return;
      gateEl.dataset.wired = '1';
      pre.addEventListener('click', function (ev) {
        if (!gateOpen || preDone) return;
        var t = ev.target;
        if (!t) return;
        if (t.id === 'preloader-gate-close' || t.id === 'preloader-gate-skip') {
          onGateAction(ev, false);
          return;
        }
        if (t.id === 'preloader-gate-join') {
          onGateAction(ev, true);
          return;
        }
        if (t.classList && t.classList.contains('preloader-email-gate__backdrop')) {
          onGateAction(ev, false);
        }
      }, true);
      var emailInp = document.getElementById('preloader-gate-email');
      if (emailInp) {
        emailInp.addEventListener('keydown', function (ev) {
          if (ev.key === 'Enter') { ev.preventDefault(); dismissEmailGate(true); }
        });
      }
      document.addEventListener('keydown', function (ev) {
        if (!gateOpen || preDone) return;
        if (ev.key === 'Escape') { ev.preventDefault(); dismissEmailGate(false); }
      });
    }
    wireEmailGate();
    window.addEventListener('pageshow', function (ev) {
      if (!ev.persisted || preDone) return;
      if (gateOpen) {
        if (gateEl) {
          gateEl.classList.remove('is-open');
          gateEl.setAttribute('aria-hidden', 'true');
        }
        pre.classList.remove('gate-open');
        gateOpen = false;
        hidePre();
        return;
      }
      rearmEnterButton();
    });

    function skipIntroAnim() {
      if (preDone) return;
      if (window.Orrery3D && typeof Orrery3D.skipIntro === 'function') {
        Orrery3D.skipIntro();
      } else {
        revealEnter(true);
      }
    }

    var skipIntroBtn = document.getElementById('preloader-skip-intro');
    if (skipIntroBtn) {
      skipIntroBtn.addEventListener('click', function (ev) {
        ev.preventDefault();
        ev.stopPropagation();
        skipIntroAnim();
      });
    }

    function pulseEnterArrive() {
      if (!enterBtn || preDone) return;
      enterBtn.classList.remove('preloader-enter-btn--launch');
      enterBtn.style.pointerEvents = 'auto';
      enterBtn.style.opacity = '1';
      enterBtn.classList.remove('preloader-enter-btn--arrive');
      void enterBtn.offsetWidth;
      enterBtn.classList.add('preloader-enter-btn--arrive');
      try { enterBtn.focus({ preventScroll: true }); } catch (_) {}
    }

    function revealEnter(force) {
      if (!force) {
        if (document.body.classList.contains('preloader-intro-playing')) {
          if (++revealRetries < 240) { requestAnimationFrame(function () { revealEnter(false); }); return; }
        }
        if (window.Orrery3D) {
          if (typeof Orrery3D.isIntroPending === 'function' && Orrery3D.isIntroPending()) {
            if (++revealRetries < 240) { requestAnimationFrame(function () { revealEnter(false); }); return; }
          }
          if (typeof Orrery3D.isIntroActive === 'function' && Orrery3D.isIntroActive()) {
            if (++revealRetries < 240) { requestAnimationFrame(function () { revealEnter(false); }); return; }
          }
        }
      }
      revealRetries = 0;
      pre.classList.add('aligned', 'preloader--enter-ready');
      wireEnterButton();
      pulseEnterArrive();
    }
    // Entry reveal is driven by the orrery's onIntroDone (the sky settling) — see above.
    // The timers below are only safety nets so the button can never be unreachable.

    // No auto-dismiss: the visitor lingers on the live orrery and enters when ready.
    // Re-assert the reveal at 5s (in case 2.6s fired before the button existed), and
    // keep only a long last-resort safety net so no one is ever truly trapped.
    document.addEventListener('ap-preloader-ready', function () { revealEnter(true); });
    setTimeout(function () { revealEnter(false); }, 8000);
    setTimeout(hidePre, 90000);

    document.addEventListener('keydown', function (ev) {
      if (preDone || gateOpen) return;
      if (ev.key !== 'Enter' && ev.key !== ' ') return;
      var tag = ev.target && ev.target.tagName ? ev.target.tagName : '';
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (!pre.classList.contains('aligned') && ev.target !== enterBtn) return;
      ev.preventDefault();
      enterSite();
    });

    var joinOpt = document.getElementById('preloader-join-optional');
    if (joinOpt) {
      joinOpt.addEventListener('click', function (ev) {
        ev.preventDefault();
        showEmailGate();
      });
    }
    // (tap-anywhere-to-enter removed: the orrery is now draggable, so a drag must
    //  not dismiss; entry is the explicit button.)

    // Reduced motion: orrery skipIntro / onIntroDone drives Enter — no early timer race.
  })();
  </script>

