    function lonToDisplay(lon) {
      lon = ((lon % 360) + 360) % 360;
      var signIdx = Math.floor(lon / 30);
      var deg     = lon - signIdx * 30;
      var degStr  = Math.floor(deg) + '°' + Math.floor((deg % 1) * 60).toString().padStart(2, '0') + '′';
      return { signIdx: signIdx, degStr: degStr };
